# Copy to .env and fill in for local dev.
# .env is gitignored — never commit secrets.

# Production HA URL — Env 1 reads against this directly
PUBLIC_HA_URL=http://192.168.1.11:8123

# Long-lived access token from HA → Profile → Long-Lived Access Tokens
# Generate one named `broadsheet-dev-<machine>` so you can revoke it
# independently. Never share, never commit.
HA_TOKEN_DEV=

# Safety rails — see docs/DEV-ENVIRONMENTS.md
# Default true: every callService() blocks unless ?allow-writes=true
# in URL. Set to false ONLY in deliberate write-testing sessions.
PUBLIC_BROADSHEET_READONLY=true

# Where curation persists in dev mode (project-relative).
# In Env 2/3 the add-on writes to /data/broadsheet.json instead.
BROADSHEET_SETTINGS_PATH=./broadsheet-dev.json

# Where the audit log lands in dev. JSONL — one event per line.
BROADSHEET_AUDIT_LOG=./broadsheet-dev-audit.jsonl
