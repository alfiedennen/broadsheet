{
  "name": "@broadsheet/core",
  "version": "0.0.1",
  "private": true,
  "description": "broadsheet — editorial frontend for Home Assistant (the SPA itself)",
  "type": "module",
  "//exports": "Plugin packages import the contract types from '@broadsheet/core'. Plugins are bundled THROUGH core's own Vite build (core → registry.ts → plugin index.ts), so pointing at TS source is correct — there is no separate publish step. Plugins import-type only; the types erase at compile.",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    }
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.7",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.5",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "@broadsheet/emanations": "workspace:*",
    "@broadsheet/ghost-cloud": "workspace:*",
    "@broadsheet/harold-preset": "workspace:*",
    "@broadsheet/tmdb-tv": "workspace:*",
    "@broadsheet/voice": "workspace:*",
    "dompurify": "^3.4.3",
    "home-assistant-js-websocket": "^9.4.0",
    "marked": "^18.0.3"
  }
}
